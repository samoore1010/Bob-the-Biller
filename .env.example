# Database (required) — Railway provides this automatically when you add a PostgreSQL plugin
DATABASE_URL=postgresql://user:password@localhost:5432/billing

# Gemini AI (for narrative generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Gmail OAuth2 (for email integration)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/gmail/callback
